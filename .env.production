# ═══════════════════════════════════════════════════════════════════════════════
# Enpro Filtration Mastermind v3.0 - PRODUCTION ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Azure OpenAI (Your AI Foundry Models)
# ═══════════════════════════════════════════════════════════════════════════════

# Your Azure OpenAI endpoint from Azure Portal
# Format: https://<your-resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://enpro-filtration-ai.services.ai.azure.com/

# Your Azure OpenAI API key (from Azure Portal > Keys and Endpoint)
AZURE_OPENAI_KEY=your-azure-openai-key-here

# API version
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Model Deployment Names (from Azure AI Foundry)
# These must match EXACTLY what you deployed
# ═══════════════════════════════════════════════════════════════════════════════

# Phi-4 for classification (cheap routing)
AZURE_DEPLOYMENT_CLASSIFIER=phi-4-classifier

# GPT-4.1-mini for fast/simple responses
AZURE_DEPLOYMENT_FAST=gpt-4.1-mini

# o4-mini for complex reasoning
AZURE_DEPLOYMENT_REASONING=o4-mini-reasoning

# GPT-4.1 for deep reasoning/briefings
AZURE_DEPLOYMENT_DEEP=gpt-4.1

# GPT-5-mini for product narrowing
AZURE_DEPLOYMENT_NARROW=gpt-5-mini


# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Feature Flags
# ═══════════════════════════════════════════════════════════════════════════════

# Use the new unified handler v3.0
USE_UNIFIED_HANDLER=true

# Disable old intent routing
USE_INTENT_ROUTING=false

# Show reasoning trace in responses (set false for production)
SHOW_REASONING_TRACE=false


# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Database (Render PostgreSQL)
# ═══════════════════════════════════════════════════════════════════════════════

# Your Render PostgreSQL connection string
# Render Dashboard > PostgreSQL > Connections > External Connection String
DATABASE_URL=postgresql://user:password@host.render.com:5432/database


# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Security
# ═══════════════════════════════════════════════════════════════════════════════

# Generate a random string (e.g., from https://randomkeygen.com/)
SESSION_SECRET=your-random-secret-key-here-minimum-32-characters

# JWT secret for authentication
JWT_SECRET=your-jwt-secret-here

# Admin token for sensitive endpoints
ADMIN_TOKEN=your-admin-token

# Global PIN for pilot access
GLOBAL_PIN=1234


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Azure AI Search (For product search - migrate later)
# ═══════════════════════════════════════════════════════════════════════════════

# AZURE_SEARCH_ENDPOINT=https://enpro-search.search.windows.net
# AZURE_SEARCH_KEY=your-search-key
# AZURE_SEARCH_INDEX=enpro-products


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Azure Cosmos DB (For session storage - migrate later)
# ═══════════════════════════════════════════════════════════════════════════════

# AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
# AZURE_COSMOS_KEY=your-cosmos-key


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Azure Speech (For voice - migrate later)
# ═══════════════════════════════════════════════════════════════════════════════

# AZURE_SPEECH_KEY=your-speech-key
# AZURE_SPEECH_REGION=southcentralus


# ═══════════════════════════════════════════════════════════════════════════════
# LEGACY: Old Model Names (Keep for backward compatibility)
# ═══════════════════════════════════════════════════════════════════════════════

# These are used if USE_UNIFIED_HANDLER=false (old mode)
# AZURE_DEPLOYMENT_ROUTER=gpt-4.1-mini
# AZURE_DEPLOYMENT_REASONING_LEGACY=gpt-4o

# Azure Whisper (legacy voice)
# AZURE_WHISPER_ENDPOINT=
# AZURE_WHISPER_KEY=
# AZURE_WHISPER_DEPLOYMENT=whisper


# ═══════════════════════════════════════════════════════════════════════════════
# LOCAL PATHS
# ═══════════════════════════════════════════════════════════════════════════════

SESSION_DIR=data/sessions
AUDIT_LOG=data/audit.jsonl
KB_DIR=kb


# ═══════════════════════════════════════════════════════════════════════════════
# SERVER SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

HOST=0.0.0.0
PORT=8000
DEBUG=false


# ═══════════════════════════════════════════════════════════════════════════════
# SMTP / EMAIL (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# REPORT_EMAIL=pwnetsuite@outlook.com
