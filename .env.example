# ═══════════════════════════════════════════════════════════════════════════════
# Enpro Filtration Mastermind v3.0 - Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Azure OpenAI (For Unified Handler)
# ═══════════════════════════════════════════════════════════════════════════════

# Your Azure OpenAI endpoint
# Format: https://<your-resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Your Azure OpenAI API key (from Azure Portal)
AZURE_OPENAI_KEY=your-azure-openai-key-here

# Model deployment names (create these in Azure AI Foundry)
AZURE_DEPLOYMENT_REASONING=o3-mini-high
AZURE_DEPLOYMENT_FAST=gpt-5.4-mini

# API version
AZURE_OPENAI_API_VERSION=2024-12-01-preview


# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: Feature Flags (Choose Your Mode)
# ═══════════════════════════════════════════════════════════════════════════════

# Use the new unified handler (true = use mastermind_v3.py)
USE_UNIFIED_HANDLER=true

# Disable old intent routing
USE_INTENT_ROUTING=false

# Show reasoning trace in responses (for debugging)
SHOW_REASONING_TRACE=false


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Azure AI Search (For Full Migration)
# Uncomment these if deploying Azure AI Search
# ═══════════════════════════════════════════════════════════════════════════════

# Azure AI Search endpoint
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net

# Azure AI Search admin key
# AZURE_SEARCH_KEY=your-search-key

# Index name
# AZURE_SEARCH_INDEX=enpro-products


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Azure Cosmos DB (For Full Migration)
# Uncomment these if using Cosmos DB for session storage
# ═══════════════════════════════════════════════════════════════════════════════

# Cosmos DB endpoint
# AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/

# Cosmos DB key
# AZURE_COSMOS_KEY=your-cosmos-key

# Database name
# AZURE_COSMOS_DATABASE=enpro-sessions

# Container name
# AZURE_COSMOS_CONTAINER=conversations


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Azure Speech Services (For Voice)
# Uncomment these if using Azure Speech instead of Whisper
# ═══════════════════════════════════════════════════════════════════════════════

# Azure Speech key
# AZURE_SPEECH_KEY=your-speech-key

# Azure Speech region (e.g., southcentralus, eastus)
# AZURE_SPEECH_REGION=southcentralus

# Custom model endpoint ID (optional - if you trained a custom model)
# AZURE_SPEECH_ENDPOINT_ID=your-custom-model-id


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Azure Blob Storage (For Data Loading)
# ═══════════════════════════════════════════════════════════════════════════════

# SAS token for Azure Blob Storage
# AZURE_BLOB_SAS=your-sas-token

# Storage account name
# AZURE_STORAGE_ACCOUNT=yourstorageaccount

# Container name
# AZURE_STORAGE_CONTAINER=data


# ═══════════════════════════════════════════════════════════════════════════════
# LEGACY: Original Settings (Keep for backward compatibility)
# These are used if USE_UNIFIED_HANDLER=false
# ═══════════════════════════════════════════════════════════════════════════════

# Legacy Azure OpenAI settings
# AZURE_DEPLOYMENT_ROUTER=gpt-4.1-mini
# AZURE_DEPLOYMENT_REASONING_LEGACY=gpt-4o

# Azure Whisper (legacy voice)
# AZURE_WHISPER_ENDPOINT=https://your-whisper.cognitiveservices.azure.com/
# AZURE_WHISPER_KEY=your-whisper-key
# AZURE_WHISPER_DEPLOYMENT=whisper


# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE: PostgreSQL (Current Render Setup)
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection string (Render provides this)
DATABASE_URL=postgresql://user:password@host:5432/database


# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════════

# Session secret for signing cookies
SESSION_SECRET=your-random-secret-key-here

# JWT secret for authentication
JWT_SECRET=your-jwt-secret-here

# Admin token for sensitive endpoints
ADMIN_TOKEN=your-admin-token

# Global PIN for pilot access
GLOBAL_PIN=1234


# ═══════════════════════════════════════════════════════════════════════════════
# SERVER SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Server host
HOST=0.0.0.0

# Server port (Render sets PORT env var)
PORT=8000

# Debug mode (false for production)
DEBUG=false


# ═══════════════════════════════════════════════════════════════════════════════
# LOCAL PATHS
# ═══════════════════════════════════════════════════════════════════════════════

# Session storage directory
SESSION_DIR=data/sessions

# Audit log file
AUDIT_LOG=data/audit.jsonl

# Knowledge base directory
KB_DIR=kb


# ═══════════════════════════════════════════════════════════════════════════════
# SMTP / EMAIL (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# REPORT_EMAIL=pwnetsuite@outlook.com
